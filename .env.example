# ======================================
# LLM Provider 选择
# ======================================
# 可选: "dmxapi" (云端API) 或 "ollama" (本地模型)
LLM_PROVIDER=dmxapi

# ======================================
# Ollama 本地模型配置 (当 LLM_PROVIDER=ollama 时使用)
# ======================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-5:cloud

# ======================================
# DMXAPI 云端 API 配置 (当 LLM_PROVIDER=dmxapi 时使用)
# ======================================
DMXAPI_BASE_URL=https://www.dmxapi.cn/v1
DMXAPI_API_KEY=sk-
LLM_MODEL=gpt-4o-mini
IMAGE_MODEL=flux-2-pro

# ======================================
# Ideogram V3 图片生成配置（可选）
# ======================================
IDEOGRAM_API_KEY=
IDEOGRAM_API_URL=https://aihubmix.com/api/IdeogramAI/ideogram/generate

# ======================================
# 微信公众号配置
# ======================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ======================================
# Tavily 搜索 API 配置
# ======================================
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com

# ======================================
# 采集配置（可选）
# ======================================
ARXIV_MAX_RESULTS=30
HF_MODELS_LIMIT=20

# ======================================
# 文章生成配置（可选）
# ======================================
ARTICLE_MIN_WORDS=3000
ARTICLE_MAX_WORDS=4000

# ======================================
# 输出目录配置（可选）
# ======================================
OUTPUT_BASE_DIR=D:\公众号

# ======================================
# 代理配置（可选）
# 用于解决 GitHub/HuggingFace 等国外服务的连接问题
# ======================================
# HTTP 代理，格式: http://host:port 或 http://user:pass@host:port
HTTP_PROXY=
# HTTPS 代理，格式: https://host:port 或 https://user:pass@host:port  
HTTPS_PROXY=
# 不使用代理的域名列表，逗号分隔
NO_PROXY=localhost,127.0.0.1

# ======================================
# 高级网络配置（可选）
# ======================================
# 连接超时时间（秒）
REQUEST_TIMEOUT=30
# 请求重试次数
REQUEST_MAX_RETRIES=3
