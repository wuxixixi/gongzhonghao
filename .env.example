# ======================================
# LLM API 配置 (DMXAPI)
# ======================================
DMXAPI_BASE_URL=https://www.dmxapi.cn/v1
DMXAPI_API_KEY=sk-
LLM_MODEL=gpt-4o-mini
IMAGE_MODEL=flux-2-pro

# ======================================
# 微信公众号配置
# ======================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ======================================
# Tavily 搜索 API 配置
# ======================================
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com

# ======================================
# 采集配置（可选）
# ======================================
ARXIV_MAX_RESULTS=30
HF_MODELS_LIMIT=20

# ======================================
# 文章生成配置（可选）
# ======================================
ARTICLE_MIN_WORDS=3000
ARTICLE_MAX_WORDS=4000

# ======================================
# 输出目录配置（可选）
# ======================================
OUTPUT_BASE_DIR=D:\公众号
